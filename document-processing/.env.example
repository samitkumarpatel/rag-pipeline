# =============================================================================
# Document Processing Service — Environment Variables
#
# Copy to .env for local development:
#   cp .env.example .env
#
# All variables use the DOC_PROC_ prefix to avoid conflicts.
# In Kubernetes, inject these from ConfigMap + Secret.
# =============================================================================

# ── Service identity ───────────────────────────────────────────────────
DOC_PROC_SERVICE_NAME=document-processing
DOC_PROC_ENVIRONMENT=development        # development | staging | production
DOC_PROC_DEBUG=false
DOC_PROC_LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR

# ── Server ────────────────────────────────────────────────────────────
DOC_PROC_HOST=0.0.0.0
DOC_PROC_PORT=8082
DOC_PROC_WORKERS=1                      # Increase in production (>= 2)

# ── RabbitMQ broker ───────────────────────────────────────────────────
DOC_PROC_RABBITMQ_URL=amqp://guest:guest@localhost:5672/
DOC_PROC_CELERY_RESULT_BACKEND=rpc://   # Use redis:// for persistent results

# ── Celery workers ─────────────────────────────────────────────────────
DOC_PROC_CELERY_WORKER_CONCURRENCY=0    # 0 = auto (CPU count)
DOC_PROC_CELERY_TASK_MAX_RETRIES=3
DOC_PROC_CELERY_TASK_DEFAULT_RETRY_DELAY=60

# ── Queue names (change only if you rename existing queues) ────────────
DOC_PROC_CELERY_PDF_QUEUE=pdf_processing
DOC_PROC_CELERY_DOCX_QUEUE=docx_processing
DOC_PROC_CELERY_IMAGE_QUEUE=image_processing
DOC_PROC_CELERY_TEXT_QUEUE=text_processing

# ── Text chunking ─────────────────────────────────────────────────────
DOC_PROC_CHUNK_SIZE=512
DOC_PROC_CHUNK_OVERLAP=50

# ── Embedding (OpenAI) ────────────────────────────────────────────────
# IMPORTANT: this model must match the model used in the Query/Chat Service
DOC_PROC_EMBEDDING_MODEL=text-embedding-3-small
DOC_PROC_OPENAI_API_KEY=sk-...          # Required — set this before running
DOC_PROC_EMBEDDING_BATCH_SIZE=100

# ── Vector Store Service ──────────────────────────────────────────────
DOC_PROC_VECTOR_STORE_URL=http://localhost:8083
DOC_PROC_VECTOR_STORE_TIMEOUT_SECONDS=30

# ── File storage ──────────────────────────────────────────────────────
DOC_PROC_STORAGE_BASE_DIR=/data/rag-uploads
DOC_PROC_MAX_FILE_SIZE_BYTES=104857600  # 100 MB

# ── Observability ─────────────────────────────────────────────────────
DOC_PROC_METRICS_ENABLED=true
DOC_PROC_TRACE_SAMPLE_RATE=1.0


#--------- Local development overrides (uncomment and edit as needed) ----------------

DOC_PROC_RABBITMQ_URL=amqp://guest:guest@localhost:32834/
DOC_PROC_CELERY_RESULT_BACKEND=rpc://
DOC_PROC_VECTOR_STORE_URL=http://yet-to-come:8083
DOC_PROC_OPENAI_API_KEY=changeme
DOC_PROC_ENVIRONMENT=development
DOC_PROC_LOG_LEVEL=INFO
DOC_PROC_STORAGE_BASE_DIR=/tmp

# For RabbitMQ event consumer
DOC_PROC_INGESTION_EXCHANGE=rag.ingestion.exchange
DOC_PROC_INGESTION_ROUTING_KEY=file.uploaded
DOC_PROC_INGESTION_QUEUE=rag.file.processing.queue
DOC_PROC_INGESTION_DLQ=rag.file.processing.dlq

# For Azure OpenAI embedding provider
DOC_PROC_EMBEDDING_PROVIDER=azure_openai
DOC_PROC_AZURE_OPENAI_API_KEY=...
DOC_PROC_AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com
DOC_PROC_AZURE_OPENAI_DEPLOYMENT=text-embedding-3-small
